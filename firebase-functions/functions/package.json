{
  "name": "wenhui-attendance-functions",
  "version": "0.1.0",
  "description": "Cloud Functions for 文輝考勤系統（Firestore 版後端，分支實驗）",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "lint": "echo 'no lint configured' && exit 0",
    "serve": "firebase emulators:start --only functions,firestore",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^7.2.5"
  },
  "private": true
}
